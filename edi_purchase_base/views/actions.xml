<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_product_price_history_action" model="ir.actions.act_window">
        <field name="name">Product Price History</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">supplier.price.list</field>
        <field
            name="context"
        >{'search_default_product_tmpl_id': [active_id], 'default_product_tmpl_id': active_id}</field>
        <field
            name="search_view_id"
            ref="edi_purchase_base.view_product_price_history_search"
        />
    </record>

    <record id="picking_update_edi_action" model="ir.actions.act_window">
        <field name="name">Delivery order update</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">picking.update</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_supplier_price_list" model="ir.actions.act_window">
        <field name="name">Price History</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">supplier.price.list</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
