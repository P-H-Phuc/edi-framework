<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_partner_form" model="ir.ui.view">
        <field name="name">res.partner.edi.purchase</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="edi_core_oca.view_partner_form" />
        <field name="arch" type="xml">
            <group name="edi_main" position="inside">
                <group name="purchase" string="Purchase">
                    <field name="edi_purchase_conf_ids" colspan="6" nolabel="1">
                        <list>
                            <field name="name" />
                            <field name="trigger_id" />
                            <field name="type_id" />
                            <field name="model_id" />
                        </list>
                    </field>
                </group>
            </group>
        </field>
    </record>
</odoo>
