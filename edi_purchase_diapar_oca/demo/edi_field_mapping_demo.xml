        />
    </record>
    <record id="demo_field_mapping_ch_price" model="edi.field.mapping">
        <field name="name">Price HT</field>
        <field name="position">3</field>
        <field name="sequence_start">38</field>
        <field name="sequence_end">47</field>
        <field name="is_numeric">True</field>
        <field
            name="mapping_field_id"
            eval="ref('edi_purchase_diapar_oca.field_supplier_price_list__price')"
        />
        <field
            name="exchange_type_id"
            eval="ref('edi_purchase_diapar_oca.demo_exchange_diapar_in_purchase_price')"
        />
        <field name="decimal_precision">4</field>
    </record>
    <record id="demo_field_mapping_ch_apply_date" model="edi.field.mapping">
